# ─────────────────────────────────────────────
# ToolVault Pro – Slack Backend Environment
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Slack App Credentials
# Get these from https://api.slack.com/apps → Your App → Basic Information
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Optional: restrict which Slack workspace can use this
# SLACK_TEAM_ID=T0XXXXXXXXX

# Data storage path (relative to project root)
DB_PATH=./data/db.json

# Optional: Your hosted ToolVault frontend URL (used in messages)
APP_URL=https://your-toolvault-app.vercel.app
